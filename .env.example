# Example environment variables for BusBuddy Backend
# Copy to .env (do not commit) or set these in your shell environment.

# JWT signing secret used to issue/verify backend tokens.
# Must be at least 32 characters.
APP_SECURITY_JWT_SECRET=change-me-to-a-strong-32+-char-secret

# Optional (default is 7 days)
APP_SECURITY_JWT_EXPIRATION_MS=604800000

# Optional
APP_TIMEZONE=Asia/Kolkata
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Firebase
FIREBASE_DATABASE_URL=https://<project>.firebaseio.com/
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# GPS ingestion (optional - required only if you use global key mode)
GPS_INGEST_API_KEY=change-me
# Optional, default 120 seconds
GPS_TIMESTAMP_WINDOW_SEC=120
