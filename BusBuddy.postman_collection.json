    {
      "name": "05 - Security Boundary Checks",
      "item": [
        {
          "name": "No token -> expect 401 (POST /buses)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/buses?busCode=BUS-101&routeId=route-1"
          }
        },
        {
          "name": "Bad token -> expect 401 (POST /buses)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer not-a-valid-jwt",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/buses?busCode=BUS-101&routeId=route-1"
          }
        },
        {
          "name": "Company token on admin endpoint -> expect 403 (POST /routes/delays/recompute)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/routes/delays/recompute"
          }
        }
