              "raw": "{\n  \"company\": \"company-a\",\n  \"code\": \"10_A - B\",\n  \"stops\": {\n    \"forwardStops\": [\n      {\n        \"name\": \"Stop A\",\n        \"address\": \"Addr 1\",\n        \"coords\": { \"latitude\": 12.9716, \"longitude\": 77.5946 }\n      }\n    ],\n    \"backStops\": []\n  }\n}"
