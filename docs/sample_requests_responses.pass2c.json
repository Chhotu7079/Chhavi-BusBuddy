                "body": {}
              },
              "response": {
                "status": 400,
                "body": {
                  "timestamp": "2026-03-11T00:00:00Z",
                  "status": 400,
                  "error": "Bad Request",
                  "message": "Request validation failed",
                  "validationErrors": {
                    "forwardMinutesFromStart": "must not be null",
                    "backMinutesFromStart": "must not be null"
