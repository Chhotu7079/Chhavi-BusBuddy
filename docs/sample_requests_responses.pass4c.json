{
  "meta": {
    "generatedAt": "2026-03-11",
    "baseUrl": "{{base_url}}",
    "variables": {
      "base_url": "http://localhost:8080",
      "token": "<backend-jwt>",
      "company_id": "<firestore-company-id>",
      "bus_id": "<firestore-bus-id>",
      "gps_imei": "123456789012345"
    },
    "notes": [
      "PASS 4C: GpsDeviceController examples.",
      "Protected endpoints: OWNER or ADMIN for the company."
    ]
  },
  "controllers": [
    {
      "controller": "GpsDeviceController",
      "endpoints": [
        {
          "method": "POST",
          "path": "/companies/{companyId}/gps-devices",
          "description": "Register GPS device (IMEI) to a bus. Returns per-device secret.",
          "examples": [
            {
              "name": "Success",
              "request": {
                "path": { "companyId": "{{company_id}}" },
                "headers": { "Authorization": "Bearer {{token}}", "Content-Type": "application/json" },
                "body": { "imei": "{{gps_imei}}", "busId": "{{bus_id}}" }
              },
              "response": { "status": 200, "body": { "imei": "{{gps_imei}}", "busId": "{{bus_id}}", "companyId": "{{company_id}}", "active": true, "secret": "<device-secret>" } }
            },
            {
              "name": "Forbidden (not owner/admin)",
              "request": {
                "path": { "companyId": "{{company_id}}" },
                "headers": { "Authorization": "Bearer {{token}}", "Content-Type": "application/json" },
                "body": { "imei": "{{gps_imei}}", "busId": "{{bus_id}}" }
              },
              "response": { "status": 403, "body": { "timestamp": "2026-03-11T00:00:00Z", "status": 403, "error": "Forbidden", "message": "Owner or admin access is required" } }
            }
          ]
        },
        {
          "method": "GET",
          "path": "/companies/{companyId}/gps-devices",
          "description": "List GPS devices for a company (does not return secrets).",
          "examples": [
            {
              "name": "Success",
              "request": { "path": { "companyId": "{{company_id}}" }, "headers": { "Authorization": "Bearer {{token}}" } },
              "response": { "status": 200, "body": [ { "imei": "{{gps_imei}}", "busId": "{{bus_id}}", "companyId": "{{company_id}}", "active": true } ] }
            },
            {
              "name": "Missing token",
              "request": { "path": { "companyId": "{{company_id}}" }, "headers": {} },
              "response": { "status": 401, "body": { "timestamp": "2026-03-11T00:00:00Z", "status": 401, "error": "Unauthorized", "message": "Unauthorized" } }
            }
          ]
        }
      ]
    }
  ]
}
